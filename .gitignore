# ─────────────────────────────────────────────────────────
# Jawalgaon Dam — Dam Break Analysis Repository
# .gitignore
# ─────────────────────────────────────────────────────────

# ── Large Data Files (Excel / raw simulation outputs) ──
*.xlsx
*.xls
*.csv
*.tsv

# ── Jupyter Notebook checkpoints ──
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# ── Python ──
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/
.env
.venv
env/
venv/
ENV/

# ── Plotly / Kaleido temp files ──
*.html
orca_config.json

# ── OS Files ──
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ──
.vscode/
.idea/
*.swp
*.swo

# ── Playwright ──
playwright-state.json

# ── Zip archives (regenerated by notebooks) ──
*.zip

# ── Log files ──
*.log
